# ── Database (Neon Postgres) ──────────────────────────────────────────────
# Use the DIRECT (non "-pooler") connection string — PgBouncer transaction mode
# breaks sqlx prepared statements and LISTEN/NOTIFY.
# `just neon-setup` provisions a project and writes this line for you.
DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── fluidbox server ───────────────────────────────────────────────────────
# Must be 0.0.0.0, not loopback: sandboxes reach the control plane via
# host.docker.internal (the host gateway IP) — a 127.0.0.1 bind is
# unreachable from inside a container.
FLUIDBOX_BIND=0.0.0.0:8787
# Admin bearer token for the public /v1 API (dashboard + CLI). Generate:
#   openssl rand -hex 32
FLUIDBOX_ADMIN_TOKEN=change-me
# Where sandbox containers reach the control plane. On macOS/Windows Docker:
FLUIDBOX_PUBLIC_CONTROL_URL=http://host.docker.internal:8787
# Runtime data (workspaces, artifacts) live here:
FLUIDBOX_DATA_DIR=./data
# Sandbox image tag built by `just sandbox-build`:
FLUIDBOX_SANDBOX_IMAGE=fluidbox-sandbox-runner:dev
# Seals integration-connection credentials at rest (GitHub PATs, App
# private keys, webhook secrets). 32 bytes, hex or base64. Without it,
# Connections AND event ingress are disabled. Generate:
#   openssl rand -hex 32
FLUIDBOX_CREDENTIAL_KEY=
# Optional: GitHub API base (GHE / tests). Default: https://api.github.com
#FLUIDBOX_GITHUB_API_URL=https://api.github.com
# Optional: browser-facing GitHub base (the seamless "Connect GitHub" flow's
# manifest form target and install URLs). Default: https://github.com
#FLUIDBOX_GITHUB_WEB_URL=https://github.com
# Optional: clone-URL base for event-derived workspaces (PR head checkouts).
# Default https://github.com; the e2e points it at a file:// fixture root.
#FLUIDBOX_GITHUB_CLONE_BASE=https://github.com
# Optional: keep per-session workspace dirs after runs finish (debug aid).
#FLUIDBOX_KEEP_WORKSPACES=1
# Browser/AS-facing base URL of the control plane (no trailing slash). Feeds
# the OAuth redirect_uri (/v1/oauth/callback) and the CIMD client-id document
# (/.well-known/fluidbox-client.json) — parties that can't resolve
# host.docker.internal. Default http://127.0.0.1:8787. CIMD client identity
# is only offered when this is a public https origin (an AS must be able to
# FETCH the document); http/loopback deployments automatically use DCR.
#FLUIDBOX_PUBLIC_URL=http://127.0.0.1:8787
# Optional egress allowlist (Phase E): comma-separated CIDRs the shared SSRF
# boundary treats as public even inside a private/metadata range — a private
# LiteLLM/GHES/MCP endpoint you deliberately opt into. A malformed entry FAILS
# BOOT. Default empty (block all private/loopback/link-local/metadata targets).
#FLUIDBOX_EGRESS_ALLOW_CIDRS=10.0.0.0/8,192.168.0.0/16
# Optional egress proxy (Phase E): route ALL control-plane→internet dials (both
# hardened HTTP clients + the git fetch subprocess) through one waypoint.
#FLUIDBOX_EGRESS_PROXY=http://egress-proxy.internal:3128
# Outbound rate limits (Phase E), token buckets checked per brokered dial on
# three INDEPENDENT dimensions. 0 disables that dimension; a malformed value
# FAILS BOOT.
#FLUIDBOX_EGRESS_RATE_TENANT_PER_MIN=120
#FLUIDBOX_EGRESS_RATE_CONNECTION_PER_MIN=60
#FLUIDBOX_EGRESS_RATE_HOST_PER_MIN=120
# The PER-USER dimension (Phase F). ON BY DEFAULT at 60/min, and DURABLE-TIER
# ONLY (inert when FLUIDBOX_EGRESS_DURABLE=0). Read this one before upgrading:
# it AGGREGATES across all of a user's runs and connections at once, so a user
# running with 3 attached MCP servers — the design's working-set assumption —
# goes from an effective 3 x 60 = 180/min (the per-connection ceiling, three
# times) to 60/min in total. That is a real behaviour change for fan-out shapes.
# Runs with NO invoking user (trigger + schedule invocations) skip the dimension
# entirely rather than sharing one bucket. 0 disables it.
#FLUIDBOX_EGRESS_RATE_USER_PER_MIN=60
# Circuit breaker (Phase E), keyed per (connection, upstream host). Opens after
# THRESHOLD consecutive TRANSPORT failures (connect refused, timeout, HTTP 5xx);
# a tool result that merely reports isError means the upstream is HEALTHY and
# never trips it. While open, calls are refused before dialing and land as
# re-claimable failed_before_send execution claims.
#FLUIDBOX_EGRESS_BREAKER_THRESHOLD=5
#FLUIDBOX_EGRESS_BREAKER_OPEN_SECS=60
# Cross-replica (DURABLE) egress governance — Phase F, migration 0023, ON BY
# DEFAULT. Everything above is also enforced in-memory PER REPLICA; on its own
# that makes an N-replica deployment's real ceiling N x the configured rate and
# lets a breaker opened on one replica be ignored by the others. This adds a
# second, Postgres-backed gate under the local one (a dial must pass BOTH) and
# is what enables the per-user dimension at all. Set it to 0 to restore exactly
# Phase E's per-replica behaviour, including no per-user limiting.
#   COST: ~9 extra DB round trips per brokered dial, and every dial in one
#   tenant serialises on that tenant's single egress_rate_windows row.
#   DEGRADES: a DB error ADMITS on the local verdict and logs — it never fails
#   a dial. A permanently unusable tier (e.g. migration 0023's DML grants were
#   skipped because the runtime role did not exist yet) is reported ONCE at
#   ERROR by the boot probe, with the remediation; watch for it after upgrading.
#FLUIDBOX_EGRESS_DURABLE=1
# How many per-request LLM budget reservations one run may hold at once (Phase E,
# Gap 14). Unlike the knobs above, 0 is REFUSED at boot — a 0 ceiling would admit
# no model request at all. Default 32; a malformed value also fails boot.
#FLUIDBOX_LLM_MAX_CONCURRENT_RESERVATIONS=32

# ── Capacity + request bounds (Phase F) ───────────────────────────────────
# The database pool is SIZED, not defaulted. The deployment-wide connection count
# is replicas x (MAX_CONNECTIONS + 2 listeners) and MUST fit the Postgres/Neon
# compute's own ceiling (Neon's is ~112). IDLE_TIMEOUT must stay below Neon's
# 5-minute autosuspend or the pool hands out already-closed connections.
# For MAX_LIFETIME_SECS and IDLE_TIMEOUT_SECS, 0 means NO CAP (not "expire
# immediately"). A malformed value fails boot.
#FLUIDBOX_DB_MAX_CONNECTIONS=25
#FLUIDBOX_DB_MIN_CONNECTIONS=0
#FLUIDBOX_DB_ACQUIRE_TIMEOUT_SECS=15
#FLUIDBOX_DB_IDLE_TIMEOUT_SECS=240
#FLUIDBOX_DB_MAX_LIFETIME_SECS=1800
# Buffered request-body ceiling on BOTH listeners (bytes). Default 2 MiB — exactly
# axum's own implicit default, so making it explicit is a no-op. Exposure is
# limit x concurrent requests. Refused below 1 KiB. Raise together with the pod
# memory limit (the LLM facade buffers the whole model request).
#FLUIDBOX_MAX_REQUEST_BODY_BYTES=2097152

# ── Workspace-archive store (Phase F) ─────────────────────────────────────
# `fs` (default) keeps packed archives node-local under FLUIDBOX_DATA_DIR — single
# replica only. `s3` puts them in a bucket so ANY replica can serve ANY run's
# archive (required for replicas>1; FLUIDBOX_REPLICAS>1 with `fs` fails boot). The
# `s3` mode requires BUCKET+REGION+ACCESS_KEY_ID+SECRET_ACCESS_KEY; ENDPOINT/
# PREFIX/SESSION_TOKEN/FORCE_PATH_STYLE are optional. Secrets are redacted in logs.
#FLUIDBOX_ARCHIVE_STORE=fs
#FLUIDBOX_REPLICAS=1
#FLUIDBOX_ARCHIVE_TTL_SECS=604800
#FLUIDBOX_ARCHIVE_S3_BUCKET=fluidbox-archives
#FLUIDBOX_ARCHIVE_S3_REGION=us-east-1
#FLUIDBOX_ARCHIVE_S3_ACCESS_KEY_ID=
#FLUIDBOX_ARCHIVE_S3_SECRET_ACCESS_KEY=
#FLUIDBOX_ARCHIVE_S3_ENDPOINT=
#FLUIDBOX_ARCHIVE_S3_PREFIX=
#FLUIDBOX_ARCHIVE_S3_SESSION_TOKEN=
#FLUIDBOX_ARCHIVE_S3_FORCE_PATH_STYLE=

# ── Workload identity + operational metrics (Phase F) ──────────────────────
# Bind sandbox requests on the internal gateway to their recorded pod IP (the
# socket peer, never a header). `off` (default) is a byte-for-byte no-op; `observe`
# logs would-be denials and admits; `enforce` denies a mismatch (and, on a k8s run
# whose provider reported an address, refuses to start if the identity can't be
# recorded). A malformed value fails boot. Network-layer, not cryptographic.
#FLUIDBOX_WORKLOAD_IDENTITY=off
# Optional dedicated listener for the Prometheus metrics exposition. Metrics are
# ALWAYS available at the admin-gated GET /v1/admin/metrics; setting this adds a
# THIRD listener that serves the SAME exposition UNAUTHENTICATED (the scrape
# convention) — so bind a PRIVATE interface a scraper reaches and the internet does
# not. Nothing sensitive is exposed (no ids/hosts/credentials/payloads). Off by
# default. A bad address fails boot.
#FLUIDBOX_METRICS_BIND=127.0.0.1:9090

# ── KMS envelope sealing / per-tenant keys / RLS (Phase D — all OPTIONAL) ──
# Defaults below preserve today's single-key, shared-gateway, single-role
# behavior; a fresh clone needs none of these. Runbook: docs/hosted/kms-operations.md
#
# Envelope sealing: off (legacy single-key v1) | static (local/CI) | aws (prod).
#FLUIDBOX_KMS_MODE=off
# static mode: 32-byte hex/base64 Key-Encryption-Key (local/CI only, not managed).
#FLUIDBOX_KMS_STATIC_KEK=
# aws mode: KMS key id or ARN (IRSA-friendly). Endpoint override is a test seam.
#FLUIDBOX_KMS_AWS_KEY_ID=
#FLUIDBOX_KMS_AWS_ENDPOINT=
#
# LLM auth: shared (one deployment key) | tenant (per-tenant LiteLLM virtual key;
# master key confined to provisioning). `tenant` REQUIRES LiteLLM backed by its
# OWN Postgres — the shipped composes don't wire that, so local stays `shared`.
#FLUIDBOX_LLM_KEY_MODE=shared
# LiteLLM admin base for /key/* (defaults to LLM_UPSTREAM_URL):
#FLUIDBOX_LLM_ADMIN_URL=
# Per-tenant virtual-key ceilings (all optional; serialized only when set):
#FLUIDBOX_LLM_TENANT_MODELS=          # CSV model allowlist
#FLUIDBOX_LLM_TENANT_MAX_BUDGET=      # USD spend cap (f64)
#FLUIDBOX_LLM_TENANT_BUDGET_DURATION= # e.g. 30d
#FLUIDBOX_LLM_TENANT_TPM=             # tokens/min (i64)
#FLUIDBOX_LLM_TENANT_RPM=             # requests/min (i64)
#
# RLS pool split: set to the migration-0018 NOLOGIN role so every pooled
# connection SET ROLEs to a non-owner. Unset = single-role (RLS still binds the
# owner via FORCE) — but NOT if your DB role is a superuser or carries BYPASSRLS
# (Neon's default does), for which Postgres skips policies entirely; `just doctor`
# checks. With FLUIDBOX_REQUIRE_SSO=1 (multi-user) a bypassing pool role is a BOOT
# REFUSAL, not a warning — RLS would be applied, FORCEd and completely inert.
# The MIGRATION reads this name too (not just the pool), so ONE ROLE NAME PER
# DEPLOYMENT on a shared cluster: Postgres roles are cluster-global while the
# grants are database-local, and 0018 + boot both REFUSE a role that carries
# LOGIN/SUPERUSER/BYPASSRLS/CREATEROLE/CREATEDB/REPLICATION, is a member of
# anything, or is already granted to another principal. 0018 is STOP the old
# binary, migrate, THEN deploy (an old binary sets no GUC ⇒ zero rows, and its
# long transactions can block the migration's ACCESS EXCLUSIVE locks).
# NOT a credential boundary: SET ROLE narrows the ordinary application queries
# this process issues, but RESET ROLE returns the same connection to the migration
# owner and the process still holds the owner DATABASE_URL. Real separation needs
# distinct migration-owner and runtime-LOGIN connection strings — see
# docs/hosted/kms-operations.md §9.
#FLUIDBOX_RUNTIME_ROLE=fluidbox_runtime
# Accept a pool role that BYPASSES RLS even under FLUIDBOX_REQUIRE_SSO=1 (`1`/`true`
# downgrades the boot refusal above to a warning). Default OFF — leave it off: it
# turns 0018's policies into decoration. Local single-user work on a superuser
# database only; a hosted deployment fixes the role instead.
#FLUIDBOX_ALLOW_RLS_BYPASS=1

# ── Model gateway (LiteLLM) ───────────────────────────────────────────────
# The ONLY place the real provider key lives. Consumed by the LiteLLM
# container via docker compose — never by the server, never by a sandbox.
ANTHROPIC_API_KEY=sk-ant-api03-...
# LiteLLM proxy admin key (the facade authenticates to LiteLLM with this):
LITELLM_MASTER_KEY=sk-litellm-change-me
# Facade upstream. Point at LiteLLM (default) or directly at Anthropic
# (https://api.anthropic.com) to use the built-in tee-metering fallback.
LLM_UPSTREAM_URL=http://127.0.0.1:4000
LITELLM_IMAGE=ghcr.io/berriai/litellm:main-stable

# ── Dashboard (apps/web) ──────────────────────────────────────────────────
# The Next.js server proxies /api/fluidbox/* to the control plane and injects
# the admin token server-side. The browser never sees the token.
FLUIDBOX_API_URL=http://127.0.0.1:8787

# ── Codex (second harness; Phase 6) ──────────────────────────────────────
# OpenAI key for codex model calls (routed through LiteLLM). OPTIONAL — the
# codex live e2e tier self-skips without it.
OPENAI_API_KEY=
# Codex runner image + default model (haiku-analog cost directive).
FLUIDBOX_CODEX_SANDBOX_IMAGE=fluidbox-codex-runner:dev
FLUIDBOX_DEFAULT_CODEX_MODEL=gpt-5.4-mini
