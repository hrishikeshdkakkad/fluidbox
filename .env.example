# ── Database (Neon Postgres) ──────────────────────────────────────────────
# Use the DIRECT (non "-pooler") connection string — PgBouncer transaction mode
# breaks sqlx prepared statements and LISTEN/NOTIFY.
# Get one with: just neon-setup
DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── fluidbox server ───────────────────────────────────────────────────────
# Must be 0.0.0.0, not loopback: sandboxes reach the control plane via
# host.docker.internal (the host gateway IP) — a 127.0.0.1 bind is
# unreachable from inside a container.
FLUIDBOX_BIND=0.0.0.0:8787
# Admin bearer token for the public /v1 API (dashboard + CLI). Generate:
#   openssl rand -hex 32
FLUIDBOX_ADMIN_TOKEN=change-me
# Where sandbox containers reach the control plane. On macOS/Windows Docker:
FLUIDBOX_PUBLIC_CONTROL_URL=http://host.docker.internal:8787
# Runtime data (workspaces, artifacts) live here:
FLUIDBOX_DATA_DIR=./data
# Sandbox image tag built by `just sandbox-build`:
FLUIDBOX_SANDBOX_IMAGE=fluidbox-sandbox-runner:dev
# Seals integration-connection credentials at rest (GitHub PATs, App
# private keys, webhook secrets). 32 bytes, hex or base64. Without it,
# Connections AND event ingress are disabled. Generate:
#   openssl rand -hex 32
FLUIDBOX_CREDENTIAL_KEY=
# Optional: GitHub API base (GHE / tests). Default: https://api.github.com
#FLUIDBOX_GITHUB_API_URL=https://api.github.com
# Optional: clone-URL base for event-derived workspaces (PR head checkouts).
# Default https://github.com; the e2e points it at a file:// fixture root.
#FLUIDBOX_GITHUB_CLONE_BASE=https://github.com
# Optional: keep per-session workspace dirs after runs finish (debug aid).
#FLUIDBOX_KEEP_WORKSPACES=1
# Browser/AS-facing base URL of the control plane (no trailing slash). Feeds
# the OAuth redirect_uri (/v1/oauth/callback) and the CIMD client-id document
# (/.well-known/fluidbox-client.json) — parties that can't resolve
# host.docker.internal. Default http://127.0.0.1:8787; set your public HTTPS
# origin in production (CIMD requires https to be accepted by real ASes).
#FLUIDBOX_PUBLIC_URL=http://127.0.0.1:8787

# ── Model gateway (LiteLLM) ───────────────────────────────────────────────
# The ONLY place the real provider key lives. Consumed by the LiteLLM
# container via docker compose — never by the server, never by a sandbox.
ANTHROPIC_API_KEY=sk-ant-api03-...
# LiteLLM proxy admin key (the facade authenticates to LiteLLM with this):
LITELLM_MASTER_KEY=sk-litellm-change-me
# Facade upstream. Point at LiteLLM (default) or directly at Anthropic
# (https://api.anthropic.com) to use the built-in tee-metering fallback.
LLM_UPSTREAM_URL=http://127.0.0.1:4000
LITELLM_IMAGE=ghcr.io/berriai/litellm:main-stable

# ── Dashboard (apps/web) ──────────────────────────────────────────────────
# The Next.js server proxies /api/fluidbox/* to the control plane and injects
# the admin token server-side. The browser never sees the token.
FLUIDBOX_API_URL=http://127.0.0.1:8787
